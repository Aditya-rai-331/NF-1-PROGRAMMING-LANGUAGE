[bits 16]
[org 0x7c00]

start:
    ; --- Hardware & Stack Setup ---
    xor ax, ax
    mov ds, ax
    mov es, ax
    mov ss, ax
    mov sp, 0x7000 ; Safe Stack for i3-3220 Systems

    ; Screen Reset to 80x25 Text Mode
    mov ax, 0x0003
    int 0x10

    mov si, welcome_msg
    call print

shell_loop:
    mov si, prompt
    call print
    call get_input
    call do_logic
    jmp shell_loop

; --- Core Routines ---
print:
    mov ah, 0x0e
.loop:
    lodsb
    or al, al
    jz .done
    int 0x10
    jmp .loop
.done:
    ret

get_input:
    mov di, buffer
.next:
    mov ah, 0x00
    int 0x16
    cmp al, 13 ; Enter
    je .finish
    cmp al, 0x08 ; Backspace
    je .handle_bs
    mov ah, 0x0e
    int 0x10
    stosb
    jmp .next
.handle_bs:
    cmp di, buffer
    je .next
    dec di
    mov ah, 0x0e
    mov al, 0x08 | int 0x10
    mov al, ' '  | int 0x10
    mov al, 0x08 | int 0x10
    jmp .next
.finish:
    mov al, 0 | stosb
    mov ah, 0x0e | mov al, 13 | int 0x10 | mov al, 10 | int 0x10
    ret

; --- Command Logic ---
do_logic:
    mov si, buffer
    cmp byte [si], 0 | je .skip
    ; Check commands: NF1_INIT, NF_PY, NF_HELP, NF_CLS
    ; [Yahan strcmp logic purane email wala use hoga]
.skip:
    ret

welcome_msg db 'NF-1 SMART KERNEL v2.0 [STABLE]', 13, 10, 'By Aditya Rai & Gemini', 13, 10, 0
prompt db '[NF1@STUDENT] > ', 0
buffer times 64 db 0
times 510-($-$$) db 0
dw 0xaa55

